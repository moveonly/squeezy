      "expected_contains": [
        "IRunner"
      ]
    },
    {
      "id": "php-call-chain",
      "kind": "call_chain",
      "from": "Repository::fetch",
      "to": "Service::run",
      "expected_contains": [
        "Repository::fetch -> Service::run"
      ]
    },
    {
      "id": "php-trait-inclusion",
      "kind": "edges",
      "expected_contains": [
