---
const stages = [
  {
    zone: "local",
    num: "01",
    title: "Your question",
    caption: "“who calls this function?”"
  },
  {
    zone: "local",
    num: "02",
    title: "Local code understanding",
    caption: "15 languages · understood on your machine"
  },
  {
    zone: "local",
    num: "03",
    title: "The exact evidence",
    caption: "the right files and lines, nothing extra"
  },
  {
    zone: "remote",
    num: "04",
    title: "The model",
    caption: "a small, focused prompt"
  }
];
---

<figure
  class="evidence-loop"
  role="img"
  aria-label="A four-stage pipeline. Stages one through three (your question, local code understanding, the exact evidence) run on your machine. Only stage four, the model call, leaves your machine and is charged by the model."
>
  <div class="loop-zone loop-zone-local">
    <span class="loop-zone-label">Your machine</span>
    {
      stages
        .filter((stage) => stage.zone === "local")
        .map((stage, index, list) => (
          <>
            <div class="loop-stage">
              <span class="loop-stage-num">{stage.num}</span>
              <div class="loop-stage-body">
                <strong>{stage.title}</strong>
                <code>{stage.caption}</code>
              </div>
            </div>
            {index < list.length - 1 && <div class="loop-connector" aria-hidden="true" />}
          </>
        ))
    }
  </div>
  <div class="loop-cross" aria-hidden="true">
    <span class="loop-cross-line" />
    <span class="loop-cross-label">only this crosses the network</span>
    <span class="loop-cross-arrow">&#x2193;</span>
  </div>
  <div class="loop-zone loop-zone-remote">
    <span class="loop-zone-label">Provider</span>
    {
      stages
        .filter((stage) => stage.zone === "remote")
        .map((stage) => (
          <div class="loop-stage">
            <span class="loop-stage-num">{stage.num}</span>
            <div class="loop-stage-body">
              <strong>{stage.title}</strong>
              <code>{stage.caption}</code>
            </div>
          </div>
        ))
    }
  </div>
</figure>
