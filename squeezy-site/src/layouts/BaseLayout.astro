---
import "../styles/global.css";
import GitHubIcon from "../components/GitHubIcon.astro";
import { SITE } from "../config";

const {
  title = SITE.name,
  description = SITE.description,
  active = "",
  ogImage = "/og.svg",
  jsonLd = false
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, SITE.url).toString();
const imageUrl = new URL(ogImage, SITE.url).toString();

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: SITE.name,
  description: SITE.description,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux, Windows",
  url: SITE.url,
  downloadUrl: SITE.repoUrl,
  license: "https://www.apache.org/licenses/LICENSE-2.0",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  }
};

const navItems = [
  { href: "/how-it-works/", label: "How it works", key: "how" },
  { href: "/languages/", label: "Languages", key: "languages" },
  { href: "/providers/", label: "Providers", key: "providers" },
  { href: "/benchmarks/", label: "Benchmarks", key: "benchmarks" },
  { href: "/install/", label: "Install", key: "install" },
  { href: "/docs/", label: "Docs", key: "docs" }
];
---

<!doctype html>
<html lang="en" data-accent="amber">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#080807" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:site_name" content={SITE.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)} />
    )}
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="brand-group">
        <a class="brand" href="/" aria-label="Squeezy home" data-track-click="brand_home">
          <span class="brand-mark">sq</span>
          <span>Squeezy</span>
        </a>
        <a
          class="brand-status"
          href="/roadmap/"
          aria-label="Squeezy is pre-1.0. See the roadmap."
          data-track-click="brand_status"
        >Pre-1.0</a>
      </div>
      <nav class="site-nav" aria-label="Primary navigation">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              aria-current={active === item.key ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <a
        class="github-link"
        href={SITE.repoUrl}
        aria-label="Open Squeezy on GitHub"
        data-track-click="github_header"
        data-track-target="github"
      >
        <GitHubIcon />
        <span>GitHub</span>
      </a>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <a class="brand footer-brand" href="/" aria-label="Squeezy home" data-track-click="footer_home">
          <span class="brand-mark">sq</span>
          <span>Squeezy</span>
        </a>
        <p>
          A terminal coding agent with a local semantic graph at its core.
        </p>
        <p class="footer-meta">
          Squeezy is pre-1.0; some surfaces are marked WIP.
        </p>
      </div>
      <div class="footer-links">
        <a href="/install/" data-track-click="footer_install">Install</a>
        <a href="/docs/" data-track-click="footer_docs">Docs</a>
        <a href="/benchmarks/" data-track-click="footer_benchmarks">Benchmark</a>
        <a href="/roadmap/" data-track-click="footer_roadmap">Roadmap</a>
        <a href="/support/" data-track-click="footer_support">Support</a>
        <a href="/privacy/" data-track-click="footer_privacy">Privacy</a>
        <a href={SITE.repoUrl} data-track-click="footer_github" data-track-target="github">GitHub</a>
      </div>
    </footer>
    <script define:vars={{ telemetryEndpoint: SITE.telemetryEndpoint }}>
      (() => {
        const endpoint = telemetryEndpoint;
        const optOutKey = "squeezy_site_telemetry_opt_out";
        const visitorKey = "squeezy_site_visitor_id";
        const sessionKey = "squeezy_site_session_id";
        const dnt =
          navigator.doNotTrack === "1" ||
          window.doNotTrack === "1" ||
          navigator.globalPrivacyControl === true;

        if (!endpoint || dnt || localStorage.getItem(optOutKey) === "1") {
          return;
        }

        const uuid = () => {
          if (crypto.randomUUID) return crypto.randomUUID();
          return "10000000-1000-4000-8000-100000000000".replace(/[018]/g, (c) =>
            (Number(c) ^ (crypto.getRandomValues(new Uint8Array(1))[0] & (15 >> (Number(c) / 4)))).toString(16)
          );
        };

        const stored = (storage, key) => {
          let value = storage.getItem(key);
          if (!value) {
            value = uuid();
            storage.setItem(key, value);
          }
          return value;
        };

        const referrerKind = () => {
          if (!document.referrer) return "none";
          try {
            const referrer = new URL(document.referrer);
            if (referrer.hostname === location.hostname) return "internal";
            if (/google|bing|duckduckgo|kagi|search/i.test(referrer.hostname)) return "search";
            if (/github|x\.com|twitter|linkedin|reddit|news\.ycombinator/i.test(referrer.hostname)) return "social";
            return "external";
          } catch {
            return "external";
          }
        };

        const boundedParam = (name) => {
          const value = new URLSearchParams(location.search).get(name);
          if (!value) return undefined;
          return value.replace(/[^A-Za-z0-9._:-]/g, "").slice(0, 80) || undefined;
        };

        const basePayload = () => ({
          schema_version: 1,
          visitor_id: stored(localStorage, visitorKey),
          session_id: stored(sessionStorage, sessionKey),
          timestamp_ms: Date.now(),
          path: location.pathname,
          referrer_kind: referrerKind(),
          utm_source: boundedParam("utm_source"),
          utm_medium: boundedParam("utm_medium"),
          utm_campaign: boundedParam("utm_campaign")
        });

        const send = (event, properties = {}) => {
          const payload = JSON.stringify({
            ...basePayload(),
            event,
            ...properties
          });
          const blob = new Blob([payload], { type: "text/plain;charset=UTF-8" });
          if (navigator.sendBeacon && navigator.sendBeacon(endpoint, blob)) {
            return;
          }
          fetch(endpoint, {
            method: "POST",
            mode: "cors",
            credentials: "omit",
            keepalive: true,
            headers: { "content-type": "text/plain;charset=UTF-8" },
            body: payload
          }).catch(() => {});
        };

        send("squeezy_site_page_view");
        document.addEventListener("click", (event) => {
          const target = event.target instanceof Element ? event.target.closest("[data-track-click]") : null;
          if (!target) return;
          const href = target instanceof HTMLAnchorElement ? target.href : undefined;
          const external = href ? new URL(href, location.href).hostname !== location.hostname : false;
          const targetKind = target.getAttribute("data-track-target") || (external ? "other" : "internal");
          send("squeezy_site_cta_clicked", {
            cta_id: target.getAttribute("data-track-click"),
            target_kind: targetKind
          });
          if (external) {
            send("squeezy_site_outbound_clicked", {
              cta_id: target.getAttribute("data-track-click"),
              target_kind: targetKind
            });
          }
        });
      })();
    </script>
  </body>
</html>
