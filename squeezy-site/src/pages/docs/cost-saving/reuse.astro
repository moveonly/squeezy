---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import DocSections from "../../../components/DocSections.astro";
import { docPages } from "../../../docContent";

const page = docPages.reuse;
---

<DocsLayout
  title={`${page.title} · Squeezy docs`}
  description="How Squeezy avoids re-paying for repeated text: provider prompt caching, receipts for repeated reads, and deferred tool definitions."
  activeDoc="/docs/cost-saving/reuse/"
  eyebrow="cost-saving · layer 2"
  heading={page.title}
  lead={page.intro}
>
  <DocSections page={page} />
</DocsLayout>
