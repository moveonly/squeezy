---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { DOCS_NAV } from "../../config";

const descriptions: Record<string, string> = {
  "Install & upgrade": "Install on macOS, Linux, or Windows, run the first-start checks, and upgrade.",
  "How it works": "What Squeezy does locally before it calls a model, in plain terms.",
  "Cost-saving strategies": "The four layers Squeezy uses to keep the model bill down.",
  "Languages & graph": "The 15 languages with local code understanding, and what the graph gives you.",
  "Providers & models": "Bring your own key, presets, auth, and routing.",
  Configuration: "Where settings live, how they layer, and the main things you can change.",
  "Permissions & safety": "What Squeezy can do without asking, and how the sandbox works.",
  Sessions: "How work is saved, resumed, and reported.",
  "Help & troubleshooting": "Ask Squeezy about itself, diagnose startup, and report issues."
};
---

<DocsLayout
  title="Docs · Squeezy"
  description="User documentation for Squeezy: install, how it works, cost-saving strategies, languages, providers, configuration, permissions, sessions, and help."
  activeDoc="overview"
  eyebrow="docs"
  heading="Squeezy documentation."
  lead="Practical, functional docs for using Squeezy. Start with install, then read how it works, then dip into the topic you need."
>
  <section class="doc-block">
    <div class="doc-prose">
      <h2>Start here</h2>
      <p>
        If you are new, follow this order: <a href="/docs/install/">install
        Squeezy</a>, then read <a href="/docs/how-it-works/">how it works</a> to
        understand what it does locally before calling a model, then connect a
        provider from <a href="/docs/providers/">providers &amp; models</a>.
        Everything else is reference you can reach for when you need it.
      </p>
      <p>
        These pages cover the parts of Squeezy that are stable. For the exact,
        always-current detail, the same documentation ships inside the binary:
        ask <code>/help</code> or run <code>squeezy doctor</code>.
      </p>
    </div>
  </section>

  <section class="doc-block">
    <h2>All topics</h2>
    <div class="doc-card-grid">
      {
        DOCS_NAV.map((item) => (
          <a class="card" href={item.href} data-track-click={`docs_${item.label.toLowerCase().replace(/[^a-z0-9]+/g, "_").replace(/^_|_$/g, "")}`}>
            <span class="label">{item.status}</span>
            <h3>{item.label}</h3>
            <p>{descriptions[item.label]}</p>
          </a>
        ))
      }
    </div>
  </section>
</DocsLayout>
