---
import BaseLayout from "../layouts/BaseLayout.astro";
import TerminalWindow from "../components/TerminalWindow.astro";
import EvidenceLoop from "../components/EvidenceLoop.astro";
import { costPillars, operatingLoop, productSubjects } from "../facts";
---

<BaseLayout
  title="How it works · Squeezy"
  description="How Squeezy uses local static analysis, graph refreshes, bounded reads, and verification before model work."
  active="how"
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <span class="eyebrow">agent architecture</span>
      <h1>Local structure first. Model judgment second.</h1>
      <p class="lead">
        Squeezy uses local repository understanding, graph navigation, output
        shaping, compaction, and routing to prepare a narrower task before
        asking a model to reason about code.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="grid-2 align-center">
      <EvidenceLoop />
      <div class="list">
        {
          operatingLoop.map((item) => (
            <div class="list-item">
              <span class="num">{item.label}</span>
              <div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="grid-2 align-center">
      <div class="section-header">
        <span class="eyebrow">graph evidence</span>
        <h2>The graph records what is known, how fresh it is, and how confident it is.</h2>
        <p>
          Static navigation works best when the agent can see how each result
          was produced. Squeezy keeps syntax, import, candidate, external, and
          freshness labels attached so the model can move from graph evidence
          to exact reads or verifier commands.
        </p>
      </div>
      <TerminalWindow title="symbol_context output shape">
        <div class="terminal-body">
          <div class="terminal-line">
            <span class="green">path</span>
            <span>crates/squeezy-agent/src/lib.rs</span>
          </div>
          <div class="terminal-line">
            <span class="cyan">span</span>
            <span>line or byte range, source hash, and freshness</span>
          </div>
          <div class="terminal-line">
            <span class="amber">confidence</span>
            <span>syntax facts, resolved imports, candidate sets, freshness</span>
          </div>
          <div class="terminal-line">
            <span class="muted">next</span>
            <span>read_slice, reference_search, upstream_flow, bounded grep</span>
          </div>
        </div>
      </TerminalWindow>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <span class="eyebrow">cost levers</span>
      <h2>The saving happens across several local mechanisms.</h2>
    </div>
    <div class="grid-3">
      {
        costPillars.map((fact) => (
          <article class="card">
            <span class="label">{fact.label}</span>
            <h3>{fact.title}</h3>
            <p>{fact.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section band">
    <div class="section-header">
      <span class="eyebrow">product surface</span>
      <h2>Convenience features support the coding loop.</h2>
      <p>
        Squeezy is still a coding agent. Permissions, sessions, provider
        routing, local skills, MCP/web access, and validation workflows exist to
        keep the graph-first loop usable in real work.
      </p>
    </div>
    <div class="grid-3">
      {
        productSubjects.slice(0, 6).map((fact) => (
          <article class="card">
            <span class="label">{fact.label}</span>
            <h3>{fact.title}</h3>
            <p>{fact.body}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
