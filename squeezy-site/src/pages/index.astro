---
import BaseLayout from "../layouts/BaseLayout.astro";
import CostChart from "../components/CostChart.astro";
import EvidenceLoop from "../components/EvidenceLoop.astro";
import GitHubIcon from "../components/GitHubIcon.astro";
import TerminalWindow from "../components/TerminalWindow.astro";
import { SITE } from "../config";
import {
  accuracyRows,
  benchmarkRows,
  benchmarkSummary,
  costPillars,
  heroMetrics,
  operatingLoop,
  productPosition,
  productSubjects,
  providerGroups,
  trustRows
} from "../facts";
---

<BaseLayout
  title="Squeezy · Local code understanding before model context"
  description={SITE.description}
  active="home"
  jsonLd={true}
>
  <section class="hero">
    <div class="hero-copy">
      <span class="eyebrow">{productPosition.eyebrow}</span>
      <h1>{productPosition.title}</h1>
      <p class="lead">{productPosition.lead}</p>
      <div class="hero-actions">
        <a class="button" href="/install/" data-track-click="hero_install">Install Squeezy</a>
        <a class="button secondary" href="/benchmarks/" data-track-click="hero_benchmarks">See measured data</a>
        <a class="button secondary" href={SITE.repoUrl} data-track-click="hero_github" data-track-target="github">
          <GitHubIcon /> GitHub
        </a>
      </div>
    </div>
    <div class="hero-visual">
      <EvidenceLoop />
    </div>
  </section>

  <section class="metric-strip" aria-label="Squeezy product facts">
    {
      heroMetrics.map((metric) => (
        <div>
          <span>{metric.label}</span>
          <strong>{metric.value}</strong>
          <small>{metric.detail}</small>
        </div>
      ))
    }
  </section>

  <section class="section">
    <div class="section-header wide">
      <span class="eyebrow">cost strategy</span>
      <h2>The saving is a method, not a magic discount.</h2>
      <p>
        Squeezy tries to avoid the expensive default loop where a model searches,
        reads, re-reads, and accumulates file dumps before it understands the
        task. It spends local CPU first, sends compact evidence, and keeps enough
        accounting to see where tokens went.
      </p>
    </div>
    <div class="grid-3">
      {
        costPillars.map((fact) => (
          <article class="card">
            <span class="label">{fact.label}</span>
            <h3>{fact.title}</h3>
            <p>{fact.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section band">
    <div class="grid-2 align-center">
      <div class="section-header">
        <span class="eyebrow">measured data</span>
        <h2>{benchmarkSummary.totalDelta} lower total model spend on the checked-in Mini suite.</h2>
        <p>
          {benchmarkSummary.suite} The benchmark shows {benchmarkSummary.wins}
          wins and {benchmarkSummary.losses} losses; the losses stay visible
          because the graph is not always the cheapest path for every task.
        </p>
        <div class="actions">
          <a class="button" href="/benchmarks/" data-track-click="home_cost_data">Benchmark details</a>
          <a class="button secondary" href="/docs/cost-receipts/" data-track-click="home_cost_docs">
            Cost controls
          </a>
        </div>
      </div>
      <CostChart rows={benchmarkRows} />
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <span class="eyebrow">agent loop</span>
      <h2>Local graph evidence narrows the question before the model sees code.</h2>
    </div>
    <div class="flow">
      {
        operatingLoop.map((item) => (
          <article class="flow-step">
            <span>{item.label}</span>
            <strong>{item.title}</strong>
            <p>{item.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section band">
    <div class="grid-2 align-center">
      <TerminalWindow title="squeezy session">
        <div class="terminal-body">
          <div class="terminal-line">
            <span class="prompt">&gt;</span>
            <span class="command">trace the call path for OrderRouter::settle</span>
          </div>
          <div class="terminal-line">
            <span class="green">repo_map</span>
            <span>Rust graph hot · changed files indexed · unsupported paths reported</span>
          </div>
          <div class="terminal-line">
            <span class="cyan">decl_search</span>
            <span>OrderRouter::settle -> crates/orders/src/router.rs:184</span>
          </div>
          <div class="terminal-line">
            <span class="cyan">upstream_flow</span>
            <span>7 callers · resolved=5 · candidate=2 · next: read_slice</span>
          </div>
          <div class="terminal-line">
            <span class="amber">status</span>
            <span>tools 4 · read bytes 1,284 · spills 0 · cached tokens tracked</span>
          </div>
        </div>
      </TerminalWindow>
      <div class="section-header">
        <span class="eyebrow">coding first</span>
        <h2>The product is a coding agent, not only a cost meter.</h2>
        <p>
          Cost reduction works because Squeezy treats languages as first-class
          inputs. The graph can answer code navigation questions directly and
          gives the model exact slices, confidence, provenance, and next actions.
        </p>
        <div class="actions">
          <a class="button" href="/languages/" data-track-click="home_languages">Language support</a>
          <a class="button secondary" href="/how-it-works/" data-track-click="home_how">How it works</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header wide">
      <span class="eyebrow">more than navigation</span>
      <h2>The surrounding features make real sessions easier to operate.</h2>
      <p>
        The graph is the core. Around it, Squeezy adds the pieces a coding agent
        needs in practice: permissions, resumable state, provider flexibility,
        local skills, MCP/web boundaries, and evaluation discipline.
      </p>
    </div>
    <div class="grid-3">
      {
        productSubjects.map((fact) => (
          <article class="card">
            <span class="label">{fact.label}</span>
            <h3>{fact.title}</h3>
            <p>{fact.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section band">
    <div class="grid-2">
      <div>
        <div class="section-header">
          <span class="eyebrow">providers</span>
          <h2>Bring your own model and keep the optimization local.</h2>
          <p>
            Squeezy is multi-provider, but routing and cost accounting stay
            conservative: pricing depends on registry metadata, and cheap-model
            routing stays within the configured provider.
          </p>
        </div>
        <div class="matrix compact-matrix">
          {
            providerGroups.map((row) => (
              <article class="matrix-row">
                <h3>{row.name}</h3>
                <p>{row.detail}</p>
                {row.status && <span class="status-pill">{row.status}</span>}
              </article>
            ))
          }
        </div>
      </div>
      <div>
        <div class="section-header">
          <span class="eyebrow">trust surface</span>
          <h2>Keep external actions visible.</h2>
          <p>
            The site should not pretend a terminal agent is magic or invisible.
            Squeezy makes model calls, tools, reports, and telemetry explicit
            surfaces with local controls and documented platform limits.
          </p>
        </div>
        <div class="matrix compact-matrix">
          {
            trustRows.map((row) => (
              <article class="matrix-row">
                <h3>{row.name}</h3>
                <p>{row.detail}</p>
                {row.status && <span class="status-pill">{row.status}</span>}
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <span class="eyebrow">validation</span>
      <h2>The graph is tested against language-specific oracles.</h2>
      <p>
        Production navigation stays tree-sitter/local-analysis first. Benchmarks
        use slower compiler or language-service oracles to measure where the
        local graph is accurate and where caveats still matter.
      </p>
    </div>
    <div class="matrix">
      {
        accuracyRows.map((row) => (
          <article class="matrix-row">
            <div><h3>{row.name}</h3></div>
            <p>{row.detail}</p>
            {row.status && <span class="status-pill ok">{row.status}</span>}
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
