---
import BaseLayout from "../layouts/BaseLayout.astro";
import GitHubIcon from "../components/GitHubIcon.astro";
import TerminalWindow from "../components/TerminalWindow.astro";
import { SITE } from "../config";
import {
  genericProof,
  heroMetrics,
  leverGroups,
  productPosition,
  productSubjects
} from "../facts";
---

<BaseLayout
  title="Squeezy · The CPU does the repetitive work. Your tokens do the thinking."
  description={SITE.description}
  active="home"
  jsonLd={true}
>
  <section class="hero">
    <div class="hero-copy">
      <span class="eyebrow">{productPosition.eyebrow}</span>
      <h1>{productPosition.title}<br />{productPosition.titleCont}</h1>
      <p class="lead">{productPosition.lead}</p>
      <p class="hero-note">{productPosition.note}</p>
      <div class="hero-actions">
        <a class="button" href="/install/" data-track-click="hero_install">Install Squeezy</a>
        <a class="button secondary" href="/how-it-works/" data-track-click="hero_how">How it works</a>
        <a class="button secondary" href={SITE.repoUrl} data-track-click="hero_github" data-track-target="github">
          <GitHubIcon /> GitHub
        </a>
      </div>
    </div>
    <div class="hero-visual">
      <TerminalWindow title="squeezy">
        <div class="tw-body" role="img" aria-label="A Squeezy session: a user prompt, a plan, a targeted code read, a reasoning step, and a live working step shown on a tree rail.">
          <div class="tw-row"><span class="tw-coin">☽</span> <span class="tw-user">add a /cost summary to the status line</span></div>
          <div class="tw-row"><span class="tw-rail">│</span></div>
          <div class="tw-row"><span class="tw-rail">├─ </span><span class="mk-plan">◇</span> <span class="tw-node">Plan</span></div>
          <div class="tw-row"><span class="tw-rail">│   </span><span class="tw-dim">read the status-line renderer</span></div>
          <div class="tw-row"><span class="tw-rail">│   </span><span class="tw-dim">add a compact cost segment</span></div>
          <div class="tw-row"><span class="tw-rail">├─ </span><span class="mk-ok">✓</span> <span class="tw-node">read_slice</span> <span class="tw-dim">statusline.rs:120-148</span></div>
          <div class="tw-row"><span class="tw-rail">│   </span><span class="tw-dim">48 lines · signature only</span></div>
          <div class="tw-row"><span class="tw-rail">├─ </span><span class="mk-reason">◯</span> <span class="tw-node">Reasoning</span></div>
          <div class="tw-row"><span class="tw-rail">╰─ </span><span class="mk-star">✦</span> <span class="shimmer-word">Working</span> <span class="tw-dim">apply_patch · 4s</span></div>
        </div>
      </TerminalWindow>
    </div>
  </section>

  <section class="section band">
    <div class="lead-stat">
      <span class="eyebrow">measured</span>
      <p class="big"><span class="accent">{genericProof.stat}</span> {genericProof.detail}</p>
      <p>{genericProof.note}</p>
      <div class="actions">
        <a class="button secondary" href="/benchmarks/" data-track-click="home_benchmarks">See the benchmark</a>
      </div>
    </div>
  </section>

  <section class="metric-strip" aria-label="Squeezy at a glance">
    {
      heroMetrics.map((metric) => (
        <div>
          <span>{metric.label}</span>
          <strong>{metric.value}</strong>
          <small>{metric.detail}</small>
        </div>
      ))
    }
  </section>

  <section class="section">
    <div class="section-header wide">
      <span class="eyebrow">what it is</span>
      <h2>A coding agent that prepares locally, then asks the model.</h2>
      <p>
        Squeezy does the work a coding agent should do before it spends a model
        token: read your repository, pick the code that matters, and send the
        model a focused task instead of raw files.
      </p>
    </div>
    <div class="grid-3">
      {
        productSubjects.slice(0, 3).map((fact) => (
          <article class="card">
            <span class="label">{fact.label}</span>
            <h3>{fact.title}</h3>
            <p>{fact.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section band">
    <div class="section-header wide">
      <span class="eyebrow">how the saving happens</span>
      <h2>Four independent ways to cut waste.</h2>
      <p>
        Local code understanding is the first layer, but it is not the whole
        story, it works alongside reusing stable context, right-sizing each
        turn, and keeping the bill in plain sight.
      </p>
    </div>
    <div class="grid-2">
      {
        leverGroups.map((group, index) => (
          <a class="card" href={`/how-it-works/#${group.id}`} data-track-click={`home_lever_${group.id}`}>
            <span class:list={["card-mark", group.id]}>{`0${index + 1}`}</span>
            <h3>{group.title}</h3>
            <p>{group.why}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="split">
      <div class="split-copy">
        <div class="section-header">
          <span class="eyebrow">your model</span>
          <h2>Bring your own key. Squeezy keeps the saving local.</h2>
          <p>
            Run Squeezy against 27 provider ids, aggregators, first-party APIs,
            subscription OAuth, cloud hosts, open-weight hosts, and local
            runtimes, or any OpenAI-compatible endpoint. The context work
            happens on your machine, before the call.
          </p>
        </div>
        <div class="actions">
          <a class="button secondary" href="/support/#providers" data-track-click="home_providers">What it supports</a>
          <a class="button secondary" href="/docs/providers/" data-track-click="home_provider_docs">Provider docs</a>
        </div>
      </div>
      <div class="card code-card">
        <span class="label">get started</span>
        <pre><code>curl -fsSL https://raw.githubusercontent.com/esqueezy/squeezy/main/install.sh | sh
squeezy</code></pre>
        <div class="actions">
          <a class="button secondary" href="/install/" data-track-click="home_install_bottom">Install</a>
          <a class="button secondary" href="/docs/" data-track-click="home_docs_bottom">Docs</a>
          <a class="button secondary" href={SITE.repoUrl} data-track-click="home_github_bottom" data-track-target="github">
            <GitHubIcon /> GitHub
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
