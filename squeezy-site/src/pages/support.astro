---
import BaseLayout from "../layouts/BaseLayout.astro";
import Wip from "../components/Wip.astro";
import { SITE } from "../config";
---

<BaseLayout
  title="Support · Squeezy"
  description="How to report Squeezy issues, send redacted diagnostics, and follow the repository."
  active="docs"
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <span class="eyebrow">support</span>
      <h1>Report issues with enough context to fix them.</h1>
      <p class="lead">
        Use GitHub for public bugs and feature discussion. For product
        diagnostics, Squeezy can prepare redacted feedback and report bundles so
        maintainers can inspect failure shape without receiving your code.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="grid-3">
      <article class="card">
        <span class="label">public issue</span>
        <h3>GitHub issues</h3>
        <p>
          Use issues for reproducible bugs, platform problems, installation
          failures, provider configuration problems, and feature requests.
        </p>
        <a class="text-link" href={SITE.issuesUrl} data-track-click="support_issues" data-track-target="github">Open issues</a>
      </article>
      <article class="card">
        <span class="label">diagnostics</span>
        <h3>Redacted reports</h3>
        <p>
          Use <code>/report</code> or <code>squeezy sessions report --preview</code> to inspect the
          local redacted manifest before uploading a diagnostic archive.
        </p>
        <a class="text-link" href="/docs/troubleshooting/" data-track-click="support_troubleshooting">Report workflow</a>
      </article>
      <article class="card">
        <span class="label">security</span>
        <h3>Security</h3>
        <Wip label="WIP" />
        <p>{SITE.securityContactLabel} In the meantime, do not put secrets, private code, or report archive contents in public issues.</p>
      </article>
    </div>
  </section>
</BaseLayout>
